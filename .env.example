# Example environment configuration for vibe-thinker
# Copy to .env and adjust as needed.
# Loaded automatically if python-dotenv is installed.
#
# Precedence: CLI flags > environment variables > defaults

# Specialist model (VibeThinker-3B) llama-server endpoint
VIBE_THINKER_URL=http://127.0.0.1:8080

# Generalist model (e.g. Llama 3.2 3B) llama-server endpoint
GENERALIST_URL=http://127.0.0.1:8081

# Optional dedicated code-specialist model (e.g. ruvltra-claude-code-0.5b
# served via llama-server). When set, code tasks route here for fast plain
# generation (verified downstream by CodeVerifier/sandbox) instead of the
# VibeThinker CLR path. Leave empty to disable and route code via specialist.
CODE_SPECIALIST_URL=http://127.0.0.1:8082

# Number of parallel code candidates to generate and verify in the sandbox
# (multi-candidate "shotgun + sandbox picks winner" loop). Default 3.
CODE_CANDIDATES=3

# Job queue
RFSN_MAX_CONCURRENT=3

# CLR (Claim-Level Reliability)
RFSN_USE_CLR=true
RFSN_CLR_K=8

# Routing
RFSN_USE_EMBEDDING_ROUTER=true

# Audit log path (bi-temporal JSONL)
RFSN_AUDIT_LOG=rfsn_jobs_bitemporal.jsonl
