# Example environment configuration for vibe-thinker
# Copy to .env and adjust as needed.

# Specialist model (VibeThinker-3B) llama-server endpoint
VIBE_ENDPOINT=http://127.0.0.1:8080

# Generalist model (e.g. Llama 3.2 3B) llama-server endpoint
GENERALIST_ENDPOINT=http://127.0.0.1:8081

# CLR parameters
VIBE_USE_CLR=true
VIBE_CLR_K=8
VIBE_MAX_CONCURRENT_CLR=6

# Routing
VIBE_USE_EMBEDDING_ROUTER=true
VIBE_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Job queue
VIBE_MAX_CONCURRENT_JOBS=2

# Audit log path (bi-temporal JSONL)
VIBE_AUDIT_LOG=rfsn_jobs_bitemporal.jsonl
