# Mac local runnable profile — no Docker, Redis, Rust, or heavy services.
# Source this: export $(grep -v '^#' profiles/mac-local.env | xargs)
VIBE_PROFILE=mac-local
VIBE_MODEL_BACKEND=http
VIBE_MODEL_BASE_URL=http://localhost:8080
VIBE_CACHE_BACKEND=json
VIBE_VECTOR_BACKEND=none
VIBE_SANDBOX_MODE=disabled
VIBE_NETWORK_MODE=disabled
VIBE_FEDERATION=disabled
VIBE_RUVLLM=disabled
VIBE_AGENTDB=disabled
